{
  "name": "@mbrughelli/nestjs-typed-config",
  "version": "1.0.0",
  "description": "Type-safe configuration module for NestJS applications with Zod validation",
  "keywords": [
    "nestjs",
    "configuration",
    "typescript",
    "zod",
    "type-safe",
    "environment",
    "config"
  ],
  "author": "Michael Brughelli <mbrughelli13@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mbrughelli/nestjs-typed-config.git"
  },
  "bugs": {
    "url": "https://github.com/mbrughelli/nestjs-typed-config/issues"
  },
  "homepage": "https://github.com/mbrughelli/nestjs-typed-config#readme",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./testing": {
      "import": "./dist/testing/index.mjs",
      "require": "./dist/testing/index.js",
      "types": "./dist/testing/index.d.ts"
    }
  },
  "files": [
    "dist",
    "templates",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "build:watch": "tsup --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:badges": "jest --coverage && istanbul-badges-readme",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "typecheck": "tsc --noEmit",
    "prepack": "npm run build && npm run test",
    "release": "np"
  },
  "dependencies": {
    "zod": "^3.22.0"
  },
  "peerDependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^3.0.0",
    "reflect-metadata": "^0.1.13",
    "typescript": "^5.0.0"
  },
  "devDependencies": {
    "@nestjs/common": "^10.4.9",
    "@nestjs/config": "^3.3.0",
    "@nestjs/testing": "^10.4.9",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.50.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "istanbul-badges-readme": "^1.9.0",
    "jest": "^29.7.0",
    "np": "^8.0.0",
    "prettier": "^3.0.0",
    "reflect-metadata": "^0.1.13",
    "ts-jest": "^29.1.0",
    "tsup": "^7.0.0",
    "typescript": "^5.2.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/src"
    ],
    "testMatch": [
      "**/__tests__/**/*.ts",
      "**/?(*.)+(spec|test).ts"
    ],
    "collectCoverageFrom": [
      "src/**/*.ts",
      "!src/**/*.d.ts",
      "!src/**/__tests__/**",
      "!src/**/index.ts"
    ],
    "coverageReporters": [
      "text",
      "lcov",
      "json-summary"
    ]
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
